{
  "name": "codictate-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "prebuild:ios": "expo prebuild --platform ios",
    "prebuild": "expo prebuild",
    "eas:development": "dotenv -e .env -- eas build --profile development --platform ios --auto-submit",
    "eas:preview": "dotenv -e .env -- eas build --profile preview --platform ios --auto-submit",
    "eas:production": "dotenv -e .env -- eas build --profile production --platform ios --auto-submit",
    "eas:development-local": "dotenv -e .env -- eas build --profile development --platform ios --local",
    "eas:preview-local": "dotenv -e .env -- eas build --profile preview --platform ios --local",
    "eas:production-local": "dotenv -e .env -- eas build --profile production --platform ios --local",
    "eas:submit": "dotenv -e .env -- eas submit --platform ios",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@expo-google-fonts/iceberg": "^0.4.1",
    "@expo-google-fonts/iceland": "^0.4.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "codictate-dictation": "file:./modules/codictate-dictation",
    "expo": "^56.0.8",
    "expo-asset": "~56.0.3",
    "expo-audio": "~56.0.11",
    "expo-build-properties": "~56.0.16",
    "expo-clipboard": "~56.0.3",
    "expo-constants": "~56.0.16",
    "expo-device": "~56.0.4",
    "expo-file-system": "~56.0.7",
    "expo-font": "~56.0.5",
    "expo-glass-effect": "~56.0.4",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.9",
    "expo-linking": "~56.0.13",
    "expo-router": "~56.2.8",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "expo-widgets": "~56.0.16",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "whisper.rn": "^0.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "~19.2.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "3.8.1",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.58.1"
  },
  "private": true
}
